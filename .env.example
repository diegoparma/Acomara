# Cloud-only setup (no local models)
OPENAI_API_KEY=
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4.1-mini
TOP_K=4

# Orchestrator service
ORCHESTRATOR_PORT=8080
ORCHESTRATOR_API_KEY=

# Session agent integration (optional but recommended)
SESSION_AGENT_BASE_URL=https://session-agent-memory-live.onrender.com
SESSION_AGENT_ID=sales-agent-v1

# OpenBSP outbound send endpoint (optional)
# If empty, orchestrator returns the reply in JSON but does not send it.
OPENBSP_SEND_URL=
OPENBSP_API_KEY=

# Human handoff email (optional)
HANDOFF_EMAIL_PROVIDER=resend
HANDOFF_EMAIL_API_KEY=
HANDOFF_EMAIL_FROM=
HANDOFF_EMAIL_TO=
HANDOFF_EMAIL_COOLDOWN_SECONDS=1800
HANDOFF_SMTP_HOST=
HANDOFF_SMTP_PORT=587
HANDOFF_SMTP_USER=
HANDOFF_SMTP_PASSWORD=
HANDOFF_SMTP_STARTTLS=true

# Email verification via Have I Been Pwned API (optional, default: true)
# If enabled, the agent will:
# 1. Ask for the prospect's email after 2-4 turns of conversation
# 2. Check if the email has been compromised in known security breaches
# 3. Pause the conversation and alert the admin if a breach is detected
EMAIL_VERIFICATION_ENABLED=true
HIBP_API_KEY=
HIBP_TIMEOUT_SECONDS=10

